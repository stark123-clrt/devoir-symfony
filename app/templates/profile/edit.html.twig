{% extends 'layout/app.html.twig' %}

{% block title %}Éditer le profil{% endblock %}

{% block page_title %}Éditer le profil{% endblock %}

{% block main %}
<div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-6 lg:py-8">

    {# Retour #}
    <a href="{{ path('profile_show') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-stone-500 hover:text-stone-900 transition mb-5">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Retour au profil
    </a>

    <div class="bg-white border border-stone-300 rounded-xl p-7">
        <h2 class="font-display font-bold text-2xl mb-6" style="letter-spacing:-0.02em">Éditer le profil</h2>

        {{ form_errors(form) }}

        {{ form_start(form, {'attr': {'class': 'flex flex-col gap-4', 'novalidate': 'novalidate'}}) }}

            {# Pseudo #}
            <label class="block">
                <span class="block text-sm font-semibold text-stone-700 mb-1.5">Pseudo</span>
                {{ form_widget(form.pseudo, {
                    'attr': {
                        'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                        'placeholder': 'votre pseudo'
                    }
                }) }}
                {{ form_errors(form.pseudo) }}
            </label>

            {# Email #}
            <label class="block">
                <span class="block text-sm font-semibold text-stone-700 mb-1.5">Email</span>
                {{ form_widget(form.email, {
                    'attr': {
                        'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                        'placeholder': 'vous@studio.fr'
                    }
                }) }}
                {{ form_errors(form.email) }}
            </label>

            {# Séparateur #}
            <div class="h-px bg-stone-200 my-1"></div>
            <p class="text-sm text-stone-500 -mb-1">Laissez vide pour conserver le mot de passe actuel.</p>

            {# Nouveau mot de passe #}
            <label class="block">
                <span class="block text-sm font-semibold text-stone-700 mb-1.5">Nouveau mot de passe</span>
                {{ form_widget(form.newPassword.first, {
                    'attr': {
                        'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                        'placeholder': '••••••••'
                    }
                }) }}
                {{ form_errors(form.newPassword.first) }}
            </label>

            {# Confirmer le mot de passe #}
            <label class="block">
                <span class="block text-sm font-semibold text-stone-700 mb-1.5">Confirmer le mot de passe</span>
                {{ form_widget(form.newPassword.second, {
                    'attr': {
                        'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                        'placeholder': '••••••••'
                    }
                }) }}
                {{ form_errors(form.newPassword.second) }}
            </label>

            {# Boutons #}
            <div class="flex items-center gap-3 mt-2">
                <button type="submit"
                        class="inline-flex items-center justify-center h-11 px-5 rounded-lg bg-terracotta-600 hover:bg-terracotta-700 text-white font-semibold transition">
                    Enregistrer
                </button>
                <a href="{{ path('profile_show') }}"
                   class="inline-flex items-center justify-center h-11 px-5 rounded-lg bg-white border border-stone-300 hover:bg-stone-100 text-stone-700 font-semibold transition">
                    Annuler
                </a>
            </div>

        {{ form_end(form) }}
    </div>

</div>
{% endblock %}
