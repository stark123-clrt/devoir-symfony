{% extends 'base.html.twig' %}

{% block title %}Note protégée{% endblock %}

{% block body %}
<div class="min-h-screen grid place-items-center px-4 py-16">
    <div class="w-full max-w-[420px]">

        <a href="{{ path('app_home') }}" class="flex items-center justify-center gap-2.5 mb-6 hover:opacity-80 transition">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
                <path d="M12 2c2.5 3 1 5.5-.5 7C10 10.5 9 12.5 10 15c-2.5-1-4-3.5-3-6.5C8 5.5 10.5 4 12 2z" fill="#C2410C"/>
                <path d="M14 9c1.8 1.6 2 3.8 1 5.8-1 2-3 3.2-5 3.2 3.3-.6 4.3-3.2 3-5.5-.6-1-.4-2.2 1-3.5z" fill="#F59E0B"/>
            </svg>
            <span class="font-display font-bold text-[20px] text-stone-900" style="letter-spacing:-0.02em">Note</span>
        </a>

        <div class="bg-white border border-stone-300 rounded-xl shadow-soft p-8">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-terracotta-50 text-terracotta-600 mx-auto mb-4">
                <i data-lucide="lock" class="w-6 h-6"></i>
            </div>
            <p class="overline text-stone-400 text-center mb-1">Note privée</p>
            <h1 class="font-display font-bold text-[22px] text-center mb-1" style="letter-spacing:-0.02em">{{ note.title }}</h1>
            <p class="text-sm text-stone-400 text-center mb-6">Entrez le mot de passe pour accéder à cette note.</p>

            {% if error %}
                <div class="mb-4 px-4 py-3 rounded-lg bg-red-100 text-red-600 text-sm font-semibold">
                    {{ error }}
                </div>
            {% endif %}

            <form method="post" class="flex flex-col gap-4">
                <label class="block">
                    <span class="block text-sm font-semibold text-stone-700 mb-1.5">Mot de passe</span>
                    <input type="text" name="note_password" maxlength="4" placeholder="AA00" autofocus
                           oninput="this.value=this.value.toUpperCase()"
                           class="w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10 tracking-widest text-center font-bold text-lg uppercase">
                </label>
                <button type="submit"
                        class="w-full h-11 rounded-lg bg-terracotta-600 hover:bg-terracotta-700 text-white font-semibold transition">
                    Accéder à la note
                </button>
            </form>

            <p class="text-sm text-stone-400 text-center mt-5">
                <a href="{{ path('app_home') }}" class="font-semibold text-terracotta-600 hover:text-terracotta-700">← Retour à l'accueil</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
