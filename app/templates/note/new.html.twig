{% extends 'layout/app.html.twig' %}

{% block title %}Nouvelle note{% endblock %}
{% block page_title %}Nouvelle note{% endblock %}

{% block main %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6 lg:py-8">

    <a href="{{ path('note_index') }}"
       class="inline-flex items-center gap-1.5 text-sm font-semibold text-stone-500 hover:text-stone-900 transition mb-5">
        <i data-lucide="arrow-left" class="w-4 h-4"></i> Retour aux notes
    </a>

    <div class="bg-white border border-stone-300 rounded-xl p-7">
        <div class="flex items-center gap-3 mb-6">
            <span class="flex items-center justify-center w-10 h-10 rounded-lg bg-terracotta-50 text-terracotta-600 flex-none">
                <i data-lucide="file-plus" class="w-5 h-5"></i>
            </span>
            <div>
                <p class="overline text-stone-400">Nouvelle note</p>
                <h2 class="font-display font-bold text-xl" style="letter-spacing:-0.02em">Créer une note</h2>
            </div>
        </div>

        {{ form_errors(form) }}

        {{ form_start(form, {'attr': {'id': 'note-form', 'class': 'flex flex-col gap-5', 'novalidate': 'novalidate'}}) }}

            {# Titre #}
            <label class="block">
                <span class="block text-sm font-semibold text-stone-700 mb-1.5">Titre <span class="text-red-500">*</span></span>
                {{ form_widget(form.title, {'attr': {'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10', 'placeholder': 'Titre de votre note…', 'autofocus': 'autofocus'}}) }}
                {{ form_errors(form.title) }}
            </label>

            {# Contenu #}
            <label class="block">
                <span class="block text-sm font-semibold text-stone-700 mb-1.5">Contenu <span class="text-red-500">*</span></span>
                {{ form_widget(form.content, {'attr': {'class': 'w-full rounded-lg border border-stone-300 bg-white px-3.5 py-3 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10 resize-none', 'placeholder': 'Écrivez le contenu de votre note…', 'rows': '8', 'oninput': 'autoResize(this)'}}) }}
                {{ form_errors(form.content) }}
            </label>

            {# Visibilité #}
            <div class="rounded-xl border border-stone-200 bg-stone-50 p-4 flex flex-col gap-4">
                <p class="text-sm font-semibold text-stone-700">Visibilité</p>
                <label class="flex items-center gap-3 cursor-pointer select-none">
                    {{ form_widget(form.isPublic, {'attr': {'class': 'w-4 h-4 rounded border-stone-300 accent-terracotta-600', 'id': 'isPublicCheck', 'onchange': 'togglePassword()'}}) }}
                    <span class="text-sm text-stone-700">Note publique <span class="text-stone-400">(visible par tous)</span></span>
                </label>

                {# Mot de passe — affiché si note privée #}
                <div id="password-field" class="hidden">
                    <label class="block">
                        <span class="block text-sm font-semibold text-stone-700 mb-1.5">
                            Mot de passe <span class="text-xs font-normal text-stone-400">(2 lettres + 2 chiffres, ex: AA00)</span>
                        </span>
                        {{ form_widget(form.notePassword, {'attr': {'class': 'w-32 h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10 tracking-widest font-bold uppercase', 'placeholder': 'AA00', 'maxlength': '4', 'oninput': 'this.value=this.value.toUpperCase()'}}) }}
                        {{ form_errors(form.notePassword) }}
                    </label>
                </div>
            </div>

            {# Notes liées #}
            <label class="block">
                <span class="block text-sm font-semibold text-stone-700 mb-1.5">
                    Lier à d'autres notes <span class="text-xs font-normal text-stone-400">(optionnel)</span>
                </span>
                {{ form_widget(form.linkedNotes, {'attr': {'class': 'w-full rounded-lg border border-stone-300 bg-white px-3.5 py-2 text-[15px] text-stone-900 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10', 'size': '4'}}) }}
                <p class="text-xs text-stone-400 mt-1">Maintenez Ctrl (ou Cmd) pour sélectionner plusieurs notes.</p>
                {{ form_errors(form.linkedNotes) }}
            </label>

            {# Boutons #}
            <div class="flex items-center gap-3 pt-2 border-t border-stone-100">
                <button type="submit"
                        class="inline-flex items-center justify-center gap-2 h-11 px-6 rounded-lg bg-terracotta-600 hover:bg-terracotta-700 text-white font-semibold transition">
                    <i data-lucide="save" class="w-4 h-4"></i> Enregistrer
                </button>
                <a href="{{ path('note_index') }}"
                   class="inline-flex items-center justify-center h-11 px-5 rounded-lg bg-white border border-stone-300 hover:bg-stone-100 text-stone-700 font-semibold transition">
                    Annuler
                </a>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
  function autoResize(el) { el.style.height = 'auto'; el.style.height = el.scrollHeight + 'px'; }
  document.querySelectorAll('textarea[oninput]').forEach(t => autoResize(t));

  function togglePassword() {
    const isPublic = document.getElementById('isPublicCheck').checked;
    document.getElementById('password-field').classList.toggle('hidden', isPublic);
  }
  // Initialise au chargement
  togglePassword();
</script>
{% endblock %}
