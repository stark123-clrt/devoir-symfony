{% extends 'base.html.twig' %}

{% block title %}Connexion — Note{% endblock %}

{% block body %}
<div class="min-h-screen grid place-items-center px-4 py-16">
    <div class="w-full max-w-[420px]">

        {# Logo — cliquable vers l'accueil #}
        <a href="{{ path('app_home') }}" class="flex items-center justify-center gap-2.5 mb-6 hover:opacity-80 transition">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2c2.5 3 1 5.5-.5 7C10 10.5 9 12.5 10 15c-2.5-1-4-3.5-3-6.5C8 5.5 10.5 4 12 2z" fill="#C2410C"/>
                <path d="M14 9c1.8 1.6 2 3.8 1 5.8-1 2-3 3.2-5 3.2 3.3-.6 4.3-3.2 3-5.5-.6-1-.4-2.2 1-3.5z" fill="#F59E0B"/>
            </svg>
            <span class="font-display font-bold text-[20px] text-stone-900 whitespace-nowrap" style="letter-spacing:-0.02em">Note</span>
        </a>

        <div class="bg-white border border-stone-300 rounded-xl shadow-soft p-8">

            <p class="overline text-stone-500 mb-2">Bon retour</p>
            <h1 class="font-display font-bold text-[26px] mb-6" style="letter-spacing:-0.02em">Connectez-vous</h1>

            {% if error %}
                <div class="mb-4 px-4 py-3 rounded-lg bg-red-100 text-red-600 text-sm font-semibold">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="post" class="flex flex-col gap-4">

                {# Email #}
                <label class="block">
                    <span class="block text-sm font-semibold text-stone-700 mb-1.5">Email</span>
                    <input type="email" name="email" value="{{ last_username }}" placeholder="vous@studio.fr" autofocus autocomplete="email" required
                           class="w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10">
                </label>

                {# Mot de passe #}
                <div>
                    <div class="flex items-center justify-between mb-1.5">
                        <span class="text-sm font-semibold text-stone-700">Mot de passe</span>
                        <a href="#" class="text-sm font-semibold text-terracotta-600 hover:text-terracotta-700">Oublié ?</a>
                    </div>
                    <input type="password" name="password" placeholder="••••••••" autocomplete="current-password" required
                           class="w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10">
                </div>

                {# Se souvenir de moi #}
                <label class="flex items-center gap-2.5 text-sm text-stone-700 select-none cursor-pointer">
                    <input type="checkbox" name="_remember_me" class="w-4 h-4 rounded border-stone-300 accent-terracotta-600">
                    Se souvenir de moi
                </label>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit"
                        class="mt-1 w-full h-11 rounded-lg bg-terracotta-600 hover:bg-terracotta-700 text-white font-semibold transition">
                    Se connecter
                </button>
            </form>

            <p class="text-sm text-stone-500 text-center mt-6">
                Pas encore de compte ?
                <a href="{{ path('app_register') }}" class="font-semibold text-terracotta-600 hover:text-terracotta-700">Créer un compte</a>
            </p>

        </div>
    </div>
</div>
{% endblock %}
