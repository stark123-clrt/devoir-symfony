{% extends 'base.html.twig' %}

{% block title %}Créer un compte — Note{% endblock %}

{% block body %}
<div class="min-h-screen grid place-items-center px-4 py-16">
    <div class="w-full max-w-[420px]">

        {# Logo — cliquable vers l'accueil #}
        <a href="{{ path('app_home') }}" class="flex items-center justify-center gap-2.5 mb-6 hover:opacity-80 transition">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M12 2c2.5 3 1 5.5-.5 7C10 10.5 9 12.5 10 15c-2.5-1-4-3.5-3-6.5C8 5.5 10.5 4 12 2z" fill="#C2410C"/>
                <path d="M14 9c1.8 1.6 2 3.8 1 5.8-1 2-3 3.2-5 3.2 3.3-.6 4.3-3.2 3-5.5-.6-1-.4-2.2 1-3.5z" fill="#F59E0B"/>
            </svg>
            <span class="font-display font-bold text-[20px] text-stone-900 whitespace-nowrap" style="letter-spacing:-0.02em">Note</span>
        </a>

        <div class="bg-white border border-stone-300 rounded-xl shadow-soft p-8">

            <p class="overline text-stone-500 mb-2">Commencez</p>
            <h1 class="font-display font-bold text-[26px] mb-6" style="letter-spacing:-0.02em">Créer un compte</h1>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm, {'attr': {'class': 'flex flex-col gap-4', 'novalidate': 'novalidate'}}) }}

                {# Email #}
                <label class="block">
                    <span class="block text-sm font-semibold text-stone-700 mb-1.5">Email</span>
                    {{ form_widget(registrationForm.email, {
                        'attr': {
                            'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                            'placeholder': 'vous@studio.fr',
                            'autofocus': 'autofocus'
                        }
                    }) }}
                    {{ form_errors(registrationForm.email) }}
                </label>

                {# Pseudo #}
                <label class="block">
                    <span class="block text-sm font-semibold text-stone-700 mb-1.5">Pseudo</span>
                    {{ form_widget(registrationForm.pseudo, {
                        'attr': {
                            'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                            'placeholder': 'votre pseudo'
                        }
                    }) }}
                    {{ form_errors(registrationForm.pseudo) }}
                </label>

                {# Mot de passe #}
                <label class="block">
                    <span class="block text-sm font-semibold text-stone-700 mb-1.5">Mot de passe</span>
                    {{ form_widget(registrationForm.plainPassword.first, {
                        'attr': {
                            'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                            'placeholder': '••••••••'
                        }
                    }) }}
                    {{ form_errors(registrationForm.plainPassword.first) }}
                </label>

                {# Confirmer le mot de passe #}
                <label class="block">
                    <span class="block text-sm font-semibold text-stone-700 mb-1.5">Confirmer le mot de passe</span>
                    {{ form_widget(registrationForm.plainPassword.second, {
                        'attr': {
                            'class': 'w-full h-11 rounded-lg border border-stone-300 bg-white px-3.5 text-[15px] text-stone-900 placeholder:text-stone-400 outline-none transition focus:border-terracotta-600 focus:ring-4 focus:ring-terracotta-600/10',
                            'placeholder': '••••••••'
                        }
                    }) }}
                    {{ form_errors(registrationForm.plainPassword.second) }}
                </label>

                {# Conditions d'utilisation #}
                <label class="flex items-start gap-2.5 text-sm text-stone-700 select-none cursor-pointer">
                    {{ form_widget(registrationForm.agreeTerms, {
                        'attr': {'class': 'mt-0.5 w-4 h-4 rounded border-stone-300 accent-terracotta-600'}
                    }) }}
                    <span>J'accepte les <a href="#" class="font-semibold text-terracotta-600 hover:text-terracotta-700">conditions d'utilisation</a></span>
                </label>
                {{ form_errors(registrationForm.agreeTerms) }}

                <button type="submit"
                        class="mt-1 w-full h-11 rounded-lg bg-terracotta-600 hover:bg-terracotta-700 text-white font-semibold transition">
                    Créer le compte
                </button>

            {{ form_end(registrationForm) }}

            <p class="text-sm text-stone-500 text-center mt-6">
                Déjà inscrit ?
                <a href="{{ path('app_login') }}" class="font-semibold text-terracotta-600 hover:text-terracotta-700">Se connecter</a>
            </p>

        </div>
    </div>
</div>
{% endblock %}
