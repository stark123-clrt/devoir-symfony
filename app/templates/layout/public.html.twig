{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen flex flex-col bg-stone-50">

  {# Barre de navigation publique #}
  <header class="flex-none h-16 px-4 lg:px-8 flex items-center gap-4 border-b border-stone-200 bg-white">

    <a href="{{ path('app_home') }}"
       class="flex items-center gap-2 mr-auto hover:opacity-80 transition">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
        <path d="M12 2c2.5 3 1 5.5-.5 7C10 10.5 9 12.5 10 15c-2.5-1-4-3.5-3-6.5C8 5.5 10.5 4 12 2z" fill="#C2410C"/>
        <path d="M14 9c1.8 1.6 2 3.8 1 5.8-1 2-3 3.2-5 3.2 3.3-.6 4.3-3.2 3-5.5-.6-1-.4-2.2 1-3.5z" fill="#F59E0B"/>
      </svg>
      <span class="font-display font-bold text-[17px] text-stone-900" style="letter-spacing:-0.02em">Note</span>
    </a>

    {% block topbar_actions %}{% endblock %}

    <div class="flex items-center gap-2">
      <a href="{{ path('app_login') }}"
         class="inline-flex items-center justify-center h-9 px-4 rounded-lg text-stone-700 text-sm font-semibold hover:bg-stone-100 transition">
        Connexion
      </a>
      <a href="{{ path('app_register') }}"
         class="inline-flex items-center justify-center h-9 px-4 rounded-lg bg-terracotta-600 hover:bg-terracotta-700 text-white text-sm font-semibold transition shadow-sm">
        Inscription
      </a>
    </div>
  </header>

  {# Flash messages #}
  {% for type, messages in app.flashes(['success', 'error', 'warning']) %}
    {% for message in messages %}
      <div class="mx-4 sm:mx-6 lg:mx-8 mt-4
        {% if type == 'success' %}bg-green-50 border border-green-200 text-green-800
        {% elseif type == 'error' %}bg-red-50 border border-red-200 text-red-800
        {% else %}bg-amber-50 border border-amber-200 text-amber-800{% endif %}
        rounded-xl px-4 py-3 text-sm font-semibold flex items-center gap-2.5">
        <i data-lucide="{% if type == 'success' %}check-circle{% elseif type == 'error' %}x-circle{% else %}alert-triangle{% endif %}" class="w-4 h-4 flex-none"></i>
        {{ message }}
      </div>
    {% endfor %}
  {% endfor %}

  <main class="flex-1">
    {% block main %}{% endblock %}
  </main>

</div>

{% block scripts %}{% endblock %}
{% endblock %}
