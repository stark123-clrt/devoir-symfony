{% extends 'base.html.twig' %}

{% block title %}Note — Prise de notes personnelle{% endblock %}

{% block body %}

{# ===== HERO ===== #}
<div class="text-center px-4 pt-16 pb-10">
    <div class="flex items-center justify-center gap-2.5 mb-8">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none">
            <path d="M12 2c2.5 3 1 5.5-.5 7C10 10.5 9 12.5 10 15c-2.5-1-4-3.5-3-6.5C8 5.5 10.5 4 12 2z" fill="#C2410C"/>
            <path d="M14 9c1.8 1.6 2 3.8 1 5.8-1 2-3 3.2-5 3.2 3.3-.6 4.3-3.2 3-5.5-.6-1-.4-2.2 1-3.5z" fill="#F59E0B"/>
        </svg>
        <span class="font-display font-bold text-[22px] text-stone-900" style="letter-spacing:-0.02em">Note</span>
    </div>
    <p class="overline text-terracotta-600 mb-4">Prise de notes</p>
    <h1 class="font-display font-bold text-[42px] sm:text-[52px] leading-[1.05] mb-5" style="letter-spacing:-0.02em">
        Écrivez, organisez<br>et partagez vos idées.
    </h1>
    <p class="text-lg text-stone-500 leading-relaxed mb-9 max-w-md mx-auto">
        Créez des notes publiques ou privées, protégez-les par mot de passe et explorez les notes des autres utilisateurs.
    </p>
    <div class="flex items-center justify-center gap-3">
        <a href="{{ path('app_login') }}"
           class="inline-flex items-center justify-center h-11 px-6 rounded-lg bg-terracotta-600 hover:bg-terracotta-700 text-white font-semibold transition shadow-sm">
            Connexion
        </a>
        <a href="{{ path('app_register') }}"
           class="inline-flex items-center justify-center h-11 px-6 rounded-lg bg-white border border-stone-300 hover:bg-stone-100 text-stone-700 font-semibold transition">
            Inscription
        </a>
    </div>
</div>

{# ===== NOTES PUBLIQUES ===== #}
<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="flex items-center justify-between mb-6">
        <h2 class="font-display font-bold text-2xl" style="letter-spacing:-0.02em">Notes publiques</h2>
        <span class="text-sm text-stone-400">{{ publicNotes|length }} note{{ publicNotes|length != 1 ? 's' : '' }}</span>
    </div>

    {% if publicNotes is empty %}
        <div class="flex flex-col items-center justify-center py-16 text-center">
            <span class="flex items-center justify-center w-14 h-14 rounded-2xl bg-stone-100 text-stone-400 mb-4">
                <i data-lucide="sticky-note" class="w-7 h-7"></i>
            </span>
            <p class="font-semibold text-stone-600 mb-1">Aucune note publique pour l'instant</p>
            <p class="text-sm text-stone-400">Inscrivez-vous et partagez votre première note !</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4 lg:gap-6">
            {% for note in publicNotes %}
                <a href="{{ path('note_show', {'id': note.id}) }}"
                   class="ember-card flex flex-col bg-white border border-stone-300 rounded-xl p-5 hover:-translate-y-0.5 hover:shadow-soft transition">
                    <div class="flex items-start justify-between gap-2 mb-2">
                        <h3 class="font-semibold text-[15px] text-stone-900 leading-snug flex-1">{{ note.title }}</h3>
                        <span class="inline-flex items-center gap-1 text-[11px] font-semibold text-green-600 bg-green-100 rounded-full px-2 py-0.5 flex-none">
                            <i data-lucide="globe" class="w-3 h-3"></i> Public
                        </span>
                    </div>
                    <p class="text-sm text-stone-500 leading-relaxed flex-1 mb-4">
                        {{ note.content|slice(0, 100) }}{% if note.content|length > 100 %}…{% endif %}
                    </p>
                    <div class="flex items-center justify-between mt-auto">
                        <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-terracotta-700 bg-terracotta-50 rounded-full px-2.5 py-1">
                            <i data-lucide="clock" class="w-3 h-3"></i>
                            {{ note.createdAt|date('d M Y') }}
                        </span>
                        <span class="text-xs text-stone-400 font-semibold">par {{ note.owner.pseudo }}</span>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>

{% endblock %}
